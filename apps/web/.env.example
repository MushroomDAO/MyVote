# Snapshot Hub GraphQL endpoint
# Default: https://hub.snapshot.org/graphql
VITE_SNAPSHOT_GRAPHQL_ENDPOINT=https://hub.snapshot.org/graphql

# Snapshot Hub URL (used for vote submission via snapshot.js)
# Default: https://hub.snapshot.org
VITE_SNAPSHOT_HUB_URL=https://hub.snapshot.org

# App identifier sent with every vote submission to Snapshot Hub
# Change to your own app name to track votes from your deployment
# Default: myvote
VITE_SNAPSHOT_APP_NAME=myvote
